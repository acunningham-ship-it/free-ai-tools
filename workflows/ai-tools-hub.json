d:radial-gradient(circle,rgba(255,255,255,0.1) 0%,transparent 70%);animation:shimmer 3s ease-in-out infinite}\n@keyframes shimmer{0%,100%{transform:translateX(-30%) translateY(-30%)}50%{transform:translateX(30%) translateY(30%)}}\n.premium-section h2{font-size:1.8em;color:#fff;margin-bottom:8px;text-shadow:0 2px 10px rgba(0,0,0,0.3);position:relative;z-index:1}\n.premium-section .subtitle{color:rgba(255,255,255,0.9);font-size:1.05em;margin-bottom:20px;position:relative;z-index:1}\n.premium-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:15px;position:relative;z-index:1}\n.premium-card{background:rgba(255,255,255,0.15);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.25);border-radius:14px;padding:22px;transition:all 0.3s ease;text-decoration:none;color:#fff;display:block}\n.premium-card:hover{background:rgba(255,255,255,0.25);transform:translateY(-3px);box-shadow:0 10px 25px rgba(0,0,0,0.2)}\n.premium-card h3{font-size:1.15em;margin-bottom:6px}\n.premium-card p{font-size:0.85em;color:rgba(255,255,255,0.85);line-height:1.4;margin-bottom:10px}\n.premium-card .price{display:inline-block;background:rgba(255,255,255,0.25);padding:4px 14px;border-radius:20px;font-weight:bold;font-size:1.1em}\n.store-link{display:inline-block;margin-top:18px;background:rgba(255,255,255,0.95);color:#e0457b;padding:12px 30px;border-radius:25px;text-decoration:none;font-weight:bold;font-size:1em;transition:all 0.3s;position:relative;z-index:1}\n.store-link:hover{background:#fff;transform:scale(1.05);box-shadow:0 5px 20px rgba(0,0,0,0.2)}\n.support{text-align:center;padding:25px;background:linear-gradient(145deg,#1a1a2e,#16213e);border:1px solid rgba(255,255,255,0.1);border-radius:16px;margin-bottom:20px}\n.support h3{color:#fff;margin-bottom:8px}\n.support p{color:#aaa;font-size:0.9em;margin-bottom:15px}\n.support a{display:inline-block;padding:10px 25px;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;text-decoration:none;border-radius:25px;font-weight:bold;transition:all 0.3s}\n.support a:hover{transform:scale(1.05);box-shadow:0 5px 20px rgba(102,126,234,0.3)}\n.footer{text-align:center;padding:20px;color:#666;font-size:0.85em}\n.footer a{color:#667eea;text-decoration:none}\n</style>\n</head>\n<body>\n<div class=\"container\">\n<div class=\"hero\">\n<h1>AI Tools Hub</h1>\n<p>Free AI-powered web tools built with n8n webhooks. No signup required, no API keys needed.</p>\n<div class=\"badge\">Built by Armani | Powered by AI</div>\n</div>\n<div class=\"tools-grid\">\n<a href=\"https://crazeemedia.app.n8n.cloud/webhook/email-writer\" class=\"tool-card\">\n<div class=\"tool-icon\">&#9993;</div>\n<h3>AI Email Writer</h3>\n<p>Generate professional emails instantly. 8 email types, 6 tones. Perfect for business, outreach, and more.</p>\n<span class=\"tag\">Free</span>\n</a>\n<a href=\"https://crazeemedia.app.n8n.cloud/webhook/linkedin-writer\" class=\"tool-card\">\n<div class=\"tool-icon\">&#128101;</div>\n<h3>LinkedIn Post Generator</h3>\n<p>Create engaging LinkedIn posts with AI. 5 tones, 3 lengths, auto-generated hashtags.</p>\n<span class=\"tag\">Free</span>\n</a>\n<a href=\"https://crazeemedia.app.n8n.cloud/webhook/code-review\" class=\"tool-card\">\n<div class=\"tool-icon\">&#128269;</div>\n<h3>AI Code Reviewer</h3>\n<p>Get instant AI-powered code reviews. Supports 16+ languages with detailed feedback.</p>\n<span class=\"tag\">Free</span>\n</a>\n<a href=\"https://crazeemedia.app.n8n.cloud/webhook/roast-my-code\" class=\"tool-card\">\n<div class=\"tool-icon\">&#128293;</div>\n<h3>Roast My Code</h3>\n<p>Get your code hilariously roasted by AI. Educational comedy that helps you write better code.</p>\n<span class=\"tag\">Free &middot; Fun</span>\n</a>\n<a href=\"https://crazeemedia.app.n8n.cloud/webhook/roast-my-website\" class=\"tool-card\">\n<div class=\"tool-icon\">&#127760;</div>\n<h3>Roast My Website</h3>\n<p>Enter any URL and AI will hilariously roast the website's design, UX, and code. Viral entertainment meets design critique.</p>\n<span class=\"tag\">Free &middot; Viral</span>\n</a>\n<a href=\"https://crazeemedia.app.n8n.cloud/webhook/regex-generator\" class=\"tool-card\">\n<div class=\"tool-icon\">&#10033;</div>\n<h3>AI Regex Generator</h3>\n<p>Describe what you want to match in plain English. Get a working regex with explanations, test cases, and multi-language code.</p>\n<span class=\"tag\">Free &middot; New</span>\n</a>\n</div>\n\n<div class=\"premium-section\">\n<h2>&#11088; Premium Templates &amp; Resources</h2>\n<p class=\"subtitle\">Level up your workflow with our curated templates and guides</p>\n<div class=\"premium-grid\">\n<a href=\"https://payhip.com/b/sCTo9\" class=\"premium-card\" target=\"_blank\">\n<h3>&#128230; n8n AI Templates Bundle</h3>\n<p>Production-ready n8n workflow templates for AI automation. Email writer, code reviewer, content generator, and more.</p>\n<span class=\"price\">$4.99</span>\n</a>\n<a href=\"https://payhip.com/ArmanisDevTools\" class=\"premium-card\" target=\"_blank\">\n<h3>&#128218; Prompt Engineering Cheat Sheet</h3>\n<p>Master AI prompting with 50+ tested prompts, frameworks, and techniques for developers.</p>\n<span class=\"price\">Coming Soon</span>\n</a>\n</div>\n<div style=\"text-align:center\">\n<a href=\"https://payhip.com/ArmanisDevTools\" class=\"store-link\" target=\"_blank\">&#128722; Visit Our Store</a>\n</div>\n</div>\n\n<div class=\"support\">\n<h3>&#9829; Support This Project</h3>\n<p>These tools are free forever. If they helped you, consider buying a template or supporting on Ko-fi!</p>\n<a href=\"https://ko-fi.com/armanidev\" target=\"_blank\">Support on Ko-fi</a>\n</div>\n\n<div class=\"footer\">\n<p>Built with love by <a href=\"https://github.com/acunningham-ship-it\" target=\"_blank\">Armani</a> | Powered by n8n + AI</p>\n<p style=\"margin-top:5px\"><a href=\"https://github.com/acunningham-ship-it/free-ai-tools\" target=\"_blank\">View on GitHub</a> &middot; <a href=\"https://payhip.com/ArmanisDevTools\" target=\"_blank\">Shop Templates</a></p>\n</div>\n</div>\n</body>\n</html>",
